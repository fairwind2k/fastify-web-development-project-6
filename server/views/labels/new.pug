extends ../layouts/application.pug

block header
  = t('views.labels.new.title')

block content
  .row.justify-content-center
    .col-md-6
      +formFor()(action=route('labels') method='post')
        +input(label, 'name', errors, true, t('views.labels.name'))(type="text" placeholder=t('views.labels.name'))
        +submit(label)(value=t('views.labels.new.submit'))
