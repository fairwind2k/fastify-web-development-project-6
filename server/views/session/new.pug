extends ../layouts/application.pug

block header
  = t('views.session.new.signIn')

block content
  .row.justify-content-center
    .col-md-6
      +formFor()(action=route('session') method='post')
        +input(signInForm, 'email', errors, true, t('views.users.email'))(type="text" placeholder=t('views.users.email'))
        +input(signInForm, 'password', errors, true, t('views.users.password'))(type="password" placeholder=t('views.users.password'))
        +submit(signInForm)(value=t('views.session.new.submit'))
