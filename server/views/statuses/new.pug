extends ../layouts/application.pug

block header
  = t('views.statuses.new.title')

block content
  .row.justify-content-center
    .col-md-6
      +formFor()(action=route('statuses') method='post')
        +input(status, 'name', errors, true, t('views.statuses.name'))(type="text" placeholder=t('views.statuses.name'))
        +submit(status)(value=t('views.statuses.new.submit'))
